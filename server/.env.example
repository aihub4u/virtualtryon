# Which provider to use: "fashn" (commercial-safe, direct API) or "idm-vton" (Replicate, non-commercial license only)
TRYON_PROVIDER=fashn

# --- FASHN AI (https://fashn.ai) ---
# Get your key from https://app.fashn.ai -> API keys
FASHN_API_KEY=your_fashn_api_key_here
FASHN_MODEL=tryon-v1.6

# --- Replicate (https://replicate.com) — only needed if TRYON_PROVIDER=idm-vton ---
REPLICATE_API_TOKEN=your_replicate_api_token_here

PORT=3000
