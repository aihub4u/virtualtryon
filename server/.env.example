# Which provider to use:
# "p-image-try-on" (RECOMMENDED — official Replicate model, purpose-built for try-on,
#   cheapest option found: $0.015 first garment + $0.008/additional garment)
# "idm-vton" (Replicate — ~$0.024/run, non-commercial license)
# "fashn" (commercial-safe, direct API, ~$0.075/run)
# "fashn-selfhosted" (your own Replicate deployment of FASHN VTON v1.5 —
#   see replicate-deploy/README.md, INCLUDING its license caveat, before using this commercially)
TRYON_PROVIDER=p-image-try-on

# --- Self-hosted FASHN VTON v1.5 (only needed if TRYON_PROVIDER=fashn-selfhosted) ---
# The model name you pushed with `cog push r8.im/<you>/fashn-vton-1-5`
SELF_HOSTED_MODEL=your-username/fashn-vton-1-5

# --- Replicate (https://replicate.com) ---
# Get your token from https://replicate.com/account/api-tokens
# Used for p-image-try-on, idm-vton, and fashn-selfhosted providers.
REPLICATE_API_TOKEN=your_replicate_api_token_here

# p-image-try-on generates at native (fast/cheap) resolution by design and can
# look soft/blurry straight out of the model. By default this pipeline chains
# Pruna's own p-image-upscale model afterward (~4MP, detail+realism enhance) —
# adds a small extra cost per run but fixes the blur. Set to "false" to skip
# it and get the raw (cheaper, blurrier) try-on output.
UPSCALE_TRYON_RESULT=true

# Body-coverage check: before generating anything, checks whether the selfie
# shows shoulders/torso (not just a face). If not, the request stops
# immediately with a 422 error instead of running (and billing for) a
# try-on that would look broken on a headshot-only photo. Set to "false" to
# skip this check entirely and always attempt generation regardless of framing.
ENABLE_BODY_CHECK=true

# --- FASHN AI (https://fashn.ai) — only needed if TRYON_PROVIDER=fashn ---
FASHN_API_KEY=your_fashn_api_key_here
FASHN_MODEL=tryon-v1.6

PORT=3000

# --- Scalable async job pipeline (POST /api/jobs, GET /api/jobs/:id) ---
# See README's "Scaling for campaign traffic" section for the full architecture.

# Redis for the job queue and job status store. Upstash's free/cheap serverless
# tier works well here — no infra to manage. Get a REDIS_URL (rediss://...) from
# https://upstash.com after creating a database.
REDIS_URL=rediss://default:password@your-instance.upstash.io:6379

# Your API's public URL — Replicate needs this to send webhook callbacks.
# On Render this is your service URL, e.g. https://your-app.onrender.com
# For local testing, use an ngrok tunnel URL instead.
WEBHOOK_BASE_URL=https://your-app.onrender.com

# Get this from `replicate.webhooks.default.secret.get()` or the Replicate
# dashboard — required to verify that webhook calls actually came from Replicate.
REPLICATE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx

# Cloudflare R2 (S3-compatible) — where final results get copied before
# Replicate's 1-hour output deletion window closes. Create a bucket + API
# token at https://dash.cloudflare.com -> R2.
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET=virtual-tryon-results
# Either R2's own public r2.dev URL for the bucket, or your custom domain if
# you've mapped one to the bucket.
R2_PUBLIC_BASE_URL=https://pub-xxxxxxxx.r2.dev
